{
    "tasks": [
        // ── 资源编译（两套配置共用同一个 .rc 源文件）──────────────────────
        {
            "type": "shell",
            "label": "Compile Resource (Debug)",
            "command": "rc.exe",
            "args": [
                "/nologo",
                "/fo", "${workspaceFolder}\\build\\debug\\HawtC3.res",
                "${workspaceFolder}\\resources\\HawtC3.rc"
            ],
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": [],
            "group": "build",
            "detail": "编译 Debug 资源文件"
        },
        {
            "type": "shell",
            "label": "Compile Resource (Release)",
            "command": "rc.exe",
            "args": [
                "/nologo",
                "/fo", "${workspaceFolder}\\build\\release\\HawtC3.res",
                "${workspaceFolder}\\resources\\HawtC3.rc"
            ],
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": [],
            "group": "build",
            "detail": "编译 Release 资源文件"
        },
        {
            "type": "shell",
            "label": "Compile Resource (Release Extreme)",
            "command": "rc.exe",
            "args": [
                "/nologo",
                "/fo", "${workspaceFolder}\\build\\release_extreme\\HawtC3.res",
                "${workspaceFolder}\\resources\\HawtC3.rc"
            ],
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": [],
            "group": "build",
            "detail": "编译 Release Extreme 资源文件"
        },

        // ── Debug 构建 ────────────────────────────────────────────────────
        // 注意：Debug 必须使用 /MDd，确保与 msvcprtd/ucrtbased 调试符号一致。
        //       调试性通过 /Zi /Od /Ob0 /RTC1 + 链接器 /DEBUG:FULL 实现。
        {
            "type": "cppbuild",
            "label": "C/C++: Build Debug",
            "command": "cl.exe",
            "args": [
                "/EHsc", "/std:c++17", "/Zc:__cplusplus",
                "/MTd",                         // Debug CRT，解决 __imp__free_dbg / __imp__CrtDbgReport
                "/Zi", "/Od", "/Ob0", "/RTC1",  // 调试信息 + 关优化 + 运行时检查
                "/wd4251", "/wd4275",
                "/MP", "/W3", "/sdl", "/permissive-",
                "/openmp", "/arch:AVX",
                "/FS", "/utf-8", "/bigobj", "/Zm999",
                "/D_DEBUG", "/DNOMINMAX", "/D_CRT_SECURE_NO_WARNINGS", "/DEIGEN_USE_MKL_ALL",
                "/nologo",
                "/I", "E:\\Qahse\\Qahse",
                "/I", "E:\\Qahse\\Qahse\\Qahse\\Core",
                "/I", "E:\\Qahse\\Qahse\\include_headers\\Eigen3",
                "/I", "E:\\Qahse\\Qahse\\include_headers\\Chrono",
                "/I", "E:\\Qahse\\Qahse\\include_headers",
                "/I", "E:\\Qahse\\Qahse\\include_headers\\OpenBlas\\include",
                "/I", "E:\\Qahse\\Qahse\\src",
                "/I", "E:\\Qahse\\Qahse\\Project\\OpenXLSX-master\\OpenXLSX",
                "/I", "E:\\Qahse\\Qahse\\Project\\OpenXLSX-master\\build\\OpenXLSX",
                "/I", "E:\\Qahse\\Qahse\\Project\\OpenXLSX-master\\OpenXLSX\\headers",
                "/I", "E:\\Qahse\\Qahse\\Project\\spectra-master\\include",
                "/I", "C:\\Program Files (x86)\\Intel\\oneAPI\\mkl\\latest\\include",
                "/I", "${workspaceFolder}\\include",
                "@${workspaceFolder}\\src\\sources.rsp",
                "/Fe${workspaceFolder}\\build\\debug\\HawtC3.exe",
                "/Fo${workspaceFolder}\\build\\debug\\obj\\",
                "/Fd${workspaceFolder}\\build\\debug\\obj\\vc143.pdb",
                "/link",
                "/SUBSYSTEM:CONSOLE",
                "/DEBUG:FULL", "/INCREMENTAL", "/OPT:NOREF", "/OPT:NOICF",
                "/PDB:${workspaceFolder}\\build\\debug\\HawtC3.pdb",
                "/LIBPATH:E:\\Qahse\\Qahse\\include_headers\\OpenBlas\\lib",
                "/LIBPATH:C:\\Program Files (x86)\\Intel\\oneAPI\\mkl\\2025.3\\lib",
                "/LIBPATH:C:\\Program Files (x86)\\Intel\\oneAPI\\compiler\\2025.3\\lib",
                "/LIBPATH:E:\\HawtC3\\lib\\Debug",
                // ↓↓ Debug 版 Chrono 库目录 —— 请将此路径替换为实际位置 ↓↓
                "/LIBPATH:E:\\Qahse\\Qahse\\Project\\chrono-9.0.1\\build\\lib\\Debug",
                // ↑↑ ─────────────────────────────────────────────────────── ↑↑
                "mkl_intel_lp64_dll.lib",
                "mkl_intel_thread_dll.lib",
                "mkl_core_dll.lib",
                "libiomp5md.lib",
                "fmtd.lib",
                "gtest.lib",
                "gmock.lib",
                "OpenXLSXd.lib",
                "ChronoEngine.lib",
                "${workspaceFolder}\\build\\debug\\HawtC3.res"
            ],
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": ["$msCompile"],
            "group": { "kind": "build", "isDefault": false },
            "dependsOn": ["Compile Resource (Debug)"],
            "detail": "Debug 构建：/Zi /Od /RTC1，使用 Debug Chrono 库目录"
        },

        // ── Release 构建 ──────────────────────────────────────────────────
        {
            "type": "cppbuild",
            "label": "C/C++: Build Release",
            "command": "cl.exe",
            "args": [
                "/EHsc", "/std:c++17", "/Zc:__cplusplus",
                "/MT",
                "/O2", "/Ob2", "/Ot", "/Oi", "/GL", "/Gy",
                "/wd4251", "/wd4275",
                "/MP", "/W3", "/sdl", "/permissive-",
                "/openmp", "/arch:AVX",
                "/FS", "/utf-8", "/bigobj", "/Zm999",
                "/DNDEBUG", "/DNOMINMAX", "/D_CRT_SECURE_NO_WARNINGS", "/DEIGEN_USE_MKL_ALL",
                "/nologo",
                "/I", "E:\\Qahse\\Qahse",
                "/I", "E:\\Qahse\\Qahse\\Qahse\\Core",
                "/I", "E:\\Qahse\\Qahse\\include_headers\\Eigen3",
                "/I", "E:\\Qahse\\Qahse\\include_headers\\Chrono",
                "/I", "E:\\Qahse\\Qahse\\include_headers",
                "/I", "E:\\Qahse\\Qahse\\include_headers\\OpenBlas\\include",
                "/I", "E:\\Qahse\\Qahse\\src",
                "/I", "E:\\Qahse\\Qahse\\Project\\OpenXLSX-master\\OpenXLSX",
                "/I", "E:\\Qahse\\Qahse\\Project\\OpenXLSX-master\\build\\OpenXLSX",
                "/I", "E:\\Qahse\\Qahse\\Project\\OpenXLSX-master\\OpenXLSX\\headers",
                "/I", "E:\\Qahse\\Qahse\\Project\\spectra-master\\include",
                "/I", "C:\\Program Files (x86)\\Intel\\oneAPI\\mkl\\latest\\include",
                "/I", "${workspaceFolder}\\include",
                "@${workspaceFolder}\\src\\sources.rsp",
                "/Fe${workspaceFolder}\\build\\release\\HawtC3.exe",
                "/Fo${workspaceFolder}\\build\\release\\obj\\",
                "/Fd${workspaceFolder}\\build\\release\\obj\\vc143.pdb",
                "/link",
                "/SUBSYSTEM:CONSOLE",
                "/OPT:REF", "/OPT:ICF", "/LTCG", "/DEBUG:NONE",
                "/LIBPATH:E:\\Qahse\\Qahse\\include_headers\\OpenBlas\\lib",
                "/LIBPATH:C:\\Program Files (x86)\\Intel\\oneAPI\\mkl\\2025.3\\lib",
                "/LIBPATH:C:\\Program Files (x86)\\Intel\\oneAPI\\compiler\\2025.3\\lib",
                "/LIBPATH:E:\\Qahse\\Qahse\\Project\\chrono-9.0.1\\build\\lib\\Release",
                "/LIBPATH:E:\\HawtC3\\lib\\Release",
                "mkl_intel_lp64_dll.lib",
                "mkl_intel_thread_dll.lib",
                "mkl_core_dll.lib",
                "libiomp5md.lib",
                "fmt.lib",
                "gtest.lib",
                "gmock.lib",
                "OpenXLSX.lib",
                "ChronoEngine.lib",
                "${workspaceFolder}\\build\\release\\HawtC3.res"
            ],
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": ["$msCompile"],
            "group": { "kind": "build", "isDefault": true },
            "dependsOn": ["Compile Resource (Release)"],
            "detail": "Release 构建：全优化，关闭调试信息"
        },

        // ── Release Extreme 构建（速度优先，可能牺牲数值一致性/安全检查）────────
        {
            "type": "cppbuild",
            "label": "C/C++: Build Release Extreme",
            "command": "cl.exe",
            "args": [
                "/EHsc", "/std:c++17", "/Zc:__cplusplus",
                "/MT",
                "/O2", "/Ob2", "/Ot", "/Oi", "/GL", "/Gy", "/Gw",
                "/fp:fast", "/favor:INTEL64", "/GS-",
                "/wd4251", "/wd4275",
                "/MP", "/W3", "/permissive-",
                "/openmp", "/arch:AVX2",
                "/FS", "/utf-8", "/bigobj", "/Zm999",
                "/DNDEBUG", "/DNOMINMAX", "/D_CRT_SECURE_NO_WARNINGS", "/DEIGEN_USE_MKL_ALL",
                "/nologo",
                "/I", "E:\\Qahse\\Qahse",
                "/I", "E:\\Qahse\\Qahse\\Qahse\\Core",
                "/I", "E:\\Qahse\\Qahse\\include_headers\\Eigen3",
                "/I", "E:\\Qahse\\Qahse\\include_headers\\Chrono",
                "/I", "E:\\Qahse\\Qahse\\include_headers",
                "/I", "E:\\Qahse\\Qahse\\include_headers\\OpenBlas\\include",
                "/I", "E:\\Qahse\\Qahse\\src",
                "/I", "E:\\Qahse\\Qahse\\Project\\OpenXLSX-master\\OpenXLSX",
                "/I", "E:\\Qahse\\Qahse\\Project\\OpenXLSX-master\\build\\OpenXLSX",
                "/I", "E:\\Qahse\\Qahse\\Project\\OpenXLSX-master\\OpenXLSX\\headers",
                "/I", "E:\\Qahse\\Qahse\\Project\\spectra-master\\include",
                "/I", "C:\\Program Files (x86)\\Intel\\oneAPI\\mkl\\latest\\include",
                "/I", "${workspaceFolder}\\include",
                "@${workspaceFolder}\\src\\sources.rsp",
                "/Fe${workspaceFolder}\\build\\release_extreme\\HawtC3.exe",
                "/Fo${workspaceFolder}\\build\\release_extreme\\obj\\",
                "/Fd${workspaceFolder}\\build\\release_extreme\\obj\\vc143.pdb",
                "/link",
                "/SUBSYSTEM:CONSOLE",
                "/OPT:REF", "/OPT:ICF", "/LTCG", "/DEBUG:NONE",
                "/LIBPATH:E:\\Qahse\\Qahse\\include_headers\\OpenBlas\\lib",
                "/LIBPATH:C:\\Program Files (x86)\\Intel\\oneAPI\\mkl\\2025.3\\lib",
                "/LIBPATH:C:\\Program Files (x86)\\Intel\\oneAPI\\compiler\\2025.3\\lib",
                "/LIBPATH:E:\\Qahse\\Qahse\\Project\\chrono-9.0.1\\build\\lib\\Release",
                "/LIBPATH:E:\\HawtC3\\lib\\Release",
                "mkl_intel_lp64_dll.lib",
                "mkl_intel_thread_dll.lib",
                "mkl_core_dll.lib",
                "libiomp5md.lib",
                "fmt.lib",
                "OpenXLSX.lib",
                "gtest.lib",
                "gmock.lib",
                "ChronoEngine.lib",
                "${workspaceFolder}\\build\\release_extreme\\HawtC3.res"
            ],
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": ["$msCompile"],
            "group": { "kind": "build", "isDefault": false },
            "dependsOn": ["Compile Resource (Release Extreme)"],
            "detail": "Release Extreme：极限速度优化（AVX2/fp:fast/GS-）"
        },

        // ── 单元测试构建（Yaml + IO + Math 统一） ───────────────────────
        {
            "type": "cppbuild",
            "label": "C/C++: Build Unit Tests",
            "command": "cl.exe",
            "args": [
                "/EHsc", "/std:c++17", "/Zc:__cplusplus",
                "/MTd",
                "/Zi", "/Od", "/Ob0", "/RTC1",
                "/wd4251", "/wd4275",
                "/MP", "/W3", "/permissive-",
                "/FS", "/utf-8", "/bigobj", "/Zm999",
                "/DNDEBUG", "/DNOMINMAX", "/D_CRT_SECURE_NO_WARNINGS", "/DEIGEN_USE_MKL_ALL",
                "/nologo",
                "/I", "E:\\Qahse\\Qahse",
                "/I", "E:\\Qahse\\Qahse\\Qahse\\Core",
                "/I", "E:\\Qahse\\Qahse\\include_headers\\Eigen3",
                "/I", "E:\\Qahse\\Qahse\\include_headers\\Chrono",
                "/I", "E:\\Qahse\\Qahse\\include_headers",
                "/I", "E:\\Qahse\\Qahse\\include_headers\\OpenBlas\\include",
                "/I", "E:\\Qahse\\Qahse\\src",
                "/I", "E:\\Qahse\\Qahse\\Project\\OpenXLSX-master\\OpenXLSX",
                "/I", "E:\\Qahse\\Qahse\\Project\\OpenXLSX-master\\build\\OpenXLSX",
                "/I", "E:\\Qahse\\Qahse\\Project\\OpenXLSX-master\\OpenXLSX\\headers",
                "/I", "E:\\Qahse\\Qahse\\Project\\spectra-master\\include",
                "/I", "C:\\Program Files (x86)\\Intel\\oneAPI\\mkl\\latest\\include",
                "/I", "${workspaceFolder}\\include",
                "/I", "${workspaceFolder}\\src",
                "@${workspaceFolder}\\Test\\test_sources.rsp",
                "/Fe${workspaceFolder}\\build\\test\\UnitTests.exe",
                "/Fo${workspaceFolder}\\build\\test\\obj\\",
                "/Fd${workspaceFolder}\\build\\test\\obj\\vc143.pdb",
                "/link",
                "/SUBSYSTEM:CONSOLE",
                "/DEBUG:FULL",
                "/LIBPATH:E:\\Qahse\\Qahse\\include_headers\\OpenBlas\\lib",
                "/LIBPATH:C:\\Program Files (x86)\\Intel\\oneAPI\\mkl\\2025.3\\lib",
                "/LIBPATH:C:\\Program Files (x86)\\Intel\\oneAPI\\compiler\\2025.3\\lib",
                "/LIBPATH:E:\\HawtC3\\lib\\Debug",
                "mkl_intel_lp64_dll.lib",
                "mkl_intel_thread_dll.lib",
                "mkl_core_dll.lib",
                "libiomp5md.lib",
                "fmtd.lib",
                "gtest.lib",
                "gmock.lib",
                "OpenXLSXd.lib"
            ],
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": ["$msCompile"],
            "group": { "kind": "test", "isDefault": true },
            "detail": "构建全部 IO 模块单元测试（Yaml/IO/Math，gtest）"
        }
    ],
    "version": "2.0.0"
}